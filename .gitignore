# .gitignore — Exclude local runtime, editor, and operating-system artifacts.
# Keeps reproducible source and generated publication figures under version control.
# Author: Pasquale Marzaioli

# Local SPICE/MICE toolkit (not required by this benchmark)
mice/

# MATLAB / Octave autosaves
*.asv
*.m~
octave-workspace

# OS junk
.DS_Store

# Local run capture
run_output.log
